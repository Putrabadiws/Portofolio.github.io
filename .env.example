# Resend (kontak form) — sudah ada sebelumnya.
RESEND_API_KEY=
CONTACT_TO_EMAIL=

# Payload CMS ---------------------------------------------------------------
# Generate: openssl rand -base64 32
PAYLOAD_SECRET=

# Neon Postgres connection string (gunakan "pooled" connection untuk serverless).
# Format: postgresql://user:pass@host/db?sslmode=require
DATABASE_URI=

# Vercel Blob — buka project di Vercel > Storage > Create Blob Store > .env.local tab.
BLOB_READ_WRITE_TOKEN=
